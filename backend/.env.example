# ── NexusOps Environment — 100% Free Stack ───────────────────────────────────
APP_NAME=NexusOps
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Groq API (FREE — https://console.groq.com) ───────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama3-8b-8192

# ── GitHub (FREE — Personal Access Token) ───────────────────────────────────
# Create at: https://github.com/settings/tokens → New token (classic)
# Required scopes: repo, read:user
GITHUB_TOKEN=your-github-token-here
GITHUB_WEBHOOK_SECRET=nexusops-webhook-secret

# ── Database (SQLite — local, free) ─────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nexusops.db

# ── ChromaDB (local vector DB) ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Code Analysis ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_KB=500
MAX_FILES_PER_PR=50
SUPPORTED_LANGUAGES=python,javascript,typescript,go,java,rust,cpp

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Auto-fix settings ────────────────────────────────────────────────────────
AUTO_CREATE_PR=false
AUTO_FIX_THRESHOLD=0.80
